mae hacemos una funcion para imprimir la carrera

jocotazo imprimir_carrera(jocote largo, jocote indiceVerde, jocote indicePinton, jocote indiceMaduro) {
    
    fibra mensaje = ωω

    cosechar i en (largo) {
        qtmeten (i == indiceVerde){
            mensaje = mensaje apiar jocoteVerde
        }
        qno {
            mensaje = mensaje apiar ω ω
        }
    }
    mensaje = mensaje apiar ω|\nω

    cosechar i en (largo) {
        qtmeten (i == indicePinton){
            mensaje = mensaje apiar jocotePinton
        }
        qno {
            mensaje = mensaje apiar ω ω
        }
    }
    mensaje = mensaje apiar ω|\nω

    cosechar i en (largo) {
        qtmeten (i == indiceMaduro){
            mensaje = mensaje apiar jocoteMaduro
        }
        qno {
            mensaje = mensaje apiar ω ω
        }
    }
    mensaje = mensaje apiar ω|\nω

    desestampar()
    estampar(mensaje)
    brotar mensaje
}

mae hacemos una funcion para la carrera

jocotazo carrera_de_jocotes(jocote largo, jocote velocidad) {

    jocote indiceVerde = 0
    jocote indicePinton = 0
    jocote indiceMaduro = 0
    
    madurar (alguien_ganó(largo, indiceVerde, indicePinton, indiceMaduro) == 0) {

        imprimir_carrera(largo, indiceVerde, indicePinton, indiceMaduro)

        suave(velocidad)

        indiceVerde = rodar(indiceVerde)
        indicePinton = rodar(indicePinton)
        indiceMaduro = rodar(indiceMaduro)

    }

    brotar ωEL GANADOR ES ω apiar quien_ganó(largo, indiceVerde, indicePinton, indiceMaduro)

}

mae iniciamos el programa

fibra resultado = carrera_de_jocotes(15, 0.5)
estampar(resultado)